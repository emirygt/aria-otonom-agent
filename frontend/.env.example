# ─── Vercel Dashboard'a girilecek environment variables ──────────
# Project Settings → Environment Variables

# PostgreSQL bağlantısı (Supabase / Neon / Railway önerilir)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# NextAuth (openssl rand -base64 32 ile üret)
NEXTAUTH_SECRET="buraya-guclu-random-secret"
# Vercel deployment URL'i (örn: https://aria.vercel.app)
NEXTAUTH_URL="https://YOUR_VERCEL_URL"

# Google OAuth 2.0 — Google Console'dan al
GOOGLE_CLIENT_ID="246993900623-....apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-..."

# FastAPI backend URL'i (Render / Railway / VPS üzerinde)
NEXT_PUBLIC_API_URL="https://YOUR_BACKEND_URL"
